generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Projeto {
    id          String   @id @default(uuid())
    title       String
    desc        String
    about       String
    concluido   Boolean
    tec         String[]
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

    
model Tecnologia {
    id        String   @id @default(uuid())
    name      String   @unique
    level     Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

    
model User {
    id        String   @id @default(uuid())
    name      String
    email     String   @unique
    phone     String
    github    String
    linkedin  String
    quote     String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

    