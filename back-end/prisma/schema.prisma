generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Projeto {
    id          String   @id @default(uuid())
    title       String
    desc        String
    about       String
    concluido   Boolean
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    tec ProjetoTecnologia[]
    linkProjeto String
    linkRepo    String
    imgUrl      String
}

    
model ProjetoTecnologia {
  id          Int       @id @default(autoincrement())
  projetoId   String
  tecnologiaId String
  projeto     Projeto    @relation(fields: [projetoId], references: [id])
  tecnologia   Tecnologia @relation(fields: [tecnologiaId], references: [id])
}

model Tecnologia {
    id        String   @id @default(uuid())
    name      String   @unique
    level     Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    projetos ProjetoTecnologia[]
}

    
model User {
    id        String   @id @default(uuid())
    name      String
    email     String   @unique
    phone     String
    github    String
    linkedin  String
    quote     String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

    